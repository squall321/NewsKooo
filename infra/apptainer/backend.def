Bootstrap: docker
From: ubuntu:22.04

# NewsKoo backend image (FastAPI + workers + native C++ accel) for prod (Ubuntu 22.04).
# Build:  apptainer build backend.sif infra/apptainer/backend.def
# Run API:    apptainer run --env-file .env backend.sif api
# Run worker: apptainer run --env-file .env backend.sif worker parser

%files
    backend /opt/newskoo/backend
    native /opt/newskoo/native
    README.md /opt/newskoo/README.md

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y
    apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build pkg-config \
        curl ca-certificates git libssl-dev && rm -rf /var/lib/apt/lists/*
    # uv-managed Python 3.13
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    uv python install 3.13
    cd /opt/newskoo/backend
    uv sync --extra all --no-dev
    # Pre-fetch Playwright if browser extra installed (optional)
    # uv run playwright install --with-deps chromium

%environment
    export PATH="/root/.local/bin:$PATH"
    export NEWSKOO_ENVIRONMENT=prod
    export PYTHONUNBUFFERED=1

%runscript
    cd /opt/newskoo/backend
    case "$1" in
        api)
            exec uv run uvicorn newskoo.api.main:app --host 0.0.0.0 --port "${NEWSKOO_API_PORT:-8000}"
            ;;
        worker)
            shift
            exec uv run python -m newskoo.workers.run "$@"
            ;;
        *)
            echo "usage: run backend.sif {api|worker <stage>}"; exit 2
            ;;
    esac

%labels
    org.newskoo.component backend
