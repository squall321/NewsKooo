[Unit]
Description=NewsKoo worker (%i stage) via Apptainer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/newskoo.env
Environment=SIF_DIR=/opt/newskoo
# %i is the stage: ingest|parser|persist|results|analyzer|issues
ExecStart=/usr/bin/apptainer run --env-file /etc/newskoo.env ${SIF_DIR}/backend.sif worker %i
Restart=always
RestartSec=5
User=newskoo
Group=newskoo

[Install]
WantedBy=multi-user.target
