# NewsKoo configuration. Copy to .env and adjust. All vars are NEWSKOO_-prefixed.

# ── Environment ──────────────────────────────────────────
NEWSKOO_ENVIRONMENT=dev
NEWSKOO_LOG_LEVEL=INFO
NEWSKOO_LOG_JSON=false

# ── PostgreSQL ───────────────────────────────────────────
NEWSKOO_POSTGRES_DSN=postgresql+asyncpg://newskoo:newskoo@localhost:5432/newskoo

# ── Kafka (KRaft) ────────────────────────────────────────
NEWSKOO_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis ────────────────────────────────────────────────
NEWSKOO_REDIS_URL=redis://localhost:6379/0

# ── LLM (multi-provider) ─────────────────────────────────
NEWSKOO_LLM_PROVIDER=anthropic          # anthropic | openai | local
NEWSKOO_LLM_MODEL=claude-sonnet-4-6
NEWSKOO_EMBEDDING_PROVIDER=local        # local | openai
NEWSKOO_EMBEDDING_MODEL=bge-m3
NEWSKOO_EMBEDDING_DIM=1024
NEWSKOO_ANTHROPIC_API_KEY=
NEWSKOO_OPENAI_API_KEY=
NEWSKOO_OLLAMA_BASE_URL=http://localhost:11434

# ── Crawling / politeness ────────────────────────────────
NEWSKOO_CRAWLER_DEFAULT_RPS_PER_DOMAIN=0.5
NEWSKOO_CRAWLER_MAX_CONCURRENCY=16
NEWSKOO_CRAWLER_RESPECT_ROBOTS=true
# NEWSKOO_CRAWLER_PROXY_URL=

# ── External news APIs ───────────────────────────────────
# NEWSKOO_NEWSAPI_KEY=
# GDELT requires no key.

# ── API ──────────────────────────────────────────────────
NEWSKOO_API_PORT=8000
# NEWSKOO_API_KEY=set-to-require-x-api-key
NEWSKOO_API_CORS_ORIGINS=["http://localhost:5173"]
