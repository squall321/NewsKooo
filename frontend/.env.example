# Base URL of the NewsKoo FastAPI backend. The typed client appends "/api" and
# "/health" / "/metrics" as needed. No trailing slash.
VITE_API_BASE=http://localhost:8000

# When "true", the app serves realistic mock data instead of calling the backend.
# When "false" (default), the app calls the backend and transparently falls back
# to mocks if a request fails (e.g. the backend is offline).
VITE_USE_MOCKS=false
